#extend("Catalogue/details"):

    #export("detail-header"):
    <div class="details">
        <h1>#(title)</h1>
        #if(info):
        <p>#(info)</p>
        #endif
        #extend("Catalogue/resources")
    </div>
    #if(cover):
    <div class="artwork">
        <img src="#(cover.url)" alt="Cover of #(title)">
    </div>
    #endif
    #endexport

    #export("detail-body"):
    #endexport

#endextend
