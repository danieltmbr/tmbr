#extend("Catalogue/details"):

    #export("detail-header"):
    <div class="details">
        <h1>#(episodeTitle)</h1>
        <h3>from #(title)</h3>
        #if(info):
        <p>#(info)</p>
        #endif
        #extend("Catalogue/resources")
    </div>
    #if(artwork):
    <div class="artwork">
        <img src="#(artwork.url)" alt="Artwork image of #(title)">
    </div>
    #endif
    #endexport

    #export("detail-body"):
    #endexport

#endextend
