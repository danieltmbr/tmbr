<section id="notes-section" data-note-count="#(count(notes))">
    <header>
        <h3>Notes</h3>
        <button id="notes-gallery-open" class="icon" type="button" data-gallery-mode="notes">
            #extend("Icons/gallery")
        </button>
    </header>
    #for(note in notes):
        <div class="note-wrapper" data-index="#(index)" data-note-id="#(note.id)">
            <input type="hidden" name="notes[#(index)][id]" value="#(note.id)" />
            <textarea
                class="note-body"
                name="notes[#(index)][body]"
                placeholder="Write your thoughts..."
                autocapitalize="sentences"
                spellcheck="true"
            >#(note.body)</textarea>
            <input type="hidden" name="notes[#(index)][access]" value="private" class="note-access-fallback" />
            <div class="note-controls">
                <label class="note-access">
                    <input type="checkbox" name="notes[#(index)][access]" value="public"
                        #if(note.access == "public"):checked#endif/>
                    Public
                </label>
                <label class="language-picker">
                    #extend("Icons/globe")
                    <select name="notes[#(index)][language]">
                        <option value="en" #if(note.language == "en"):selected#endif>en</option>
                        <option value="hu" #if(note.language == "hu"):selected#endif>hu</option>
                    </select>
                </label>
                <button type="button" class="note-toggle icon" aria-label="Delete note">
                    #extend("Icons/trash")
                    #extend("Icons/recycle")
                </button>
            </div>
        </div>
    #endfor
    <template id="note-wrapper-template">
        <div class="note-wrapper" data-index="0">
            <textarea
                class="note-body"
                name="notes[0][body]"
                placeholder="Write your thoughts..."
                autocapitalize="sentences"
                spellcheck="true"
            ></textarea>
            <input type="hidden" name="notes[0][access]" value="private" class="note-access-fallback" />
            <div class="note-controls">
                <label class="note-access">
                    <input type="checkbox" name="notes[0][access]" value="public" />
                    Public
                </label>
                <label class="language-picker">
                    #extend("Icons/globe")
                    <select name="notes[0][language]">
                        #extend("Shared/language-options")
                    </select>
                </label>
            </div>
        </div>
    </template>
</section>
