#include "../Base.xcconfig"

// Production backend
API_BASE_URL = https:$()/$()/tmbr.me
WEB_CREDENTIALS_DOMAIN = tmbr.me

// SIWA App Group — all release targets share ONE Sign in with Apple service.
// Apple issues JWTs with aud = SIWA_NATIVE_APP_ID (the group primary), regardless
// of which member app requested the sign-in.  The backend validates against this ID.
//
// REQUIRED PORTAL SETUP (one-time, per environment):
//   1. identifiers → me.tmbr → Sign in with Apple → "Enable as a primary App ID"
//   2. identifiers → me.tmbr.author → Sign in with Apple → Enable, group primary = me.tmbr
//   3. identifiers → me.tmbr.personal → Sign in with Apple → Enable, group primary = me.tmbr
//
// Without this, each app's SIWA JWT will have its own bundle ID as aud, and the backend
// will treat Author/Personal as separate accounts from Reader.
SIWA_NATIVE_APP_ID = me.tmbr
